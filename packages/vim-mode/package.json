{
  "name": "@dreki-gg/pi-vim-mode",
  "version": "0.1.0",
  "description": "Always-on vim-like modal editor for pi that preserves insert-mode autocomplete",
  "keywords": [
    "pi-package",
    "pi",
    "vim",
    "modal-editor",
    "editor"
  ],
  "author": "Juan Albarran <jalbarrandev@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dreki-gg/pi-extensions",
    "directory": "packages/vim-mode"
  },
  "type": "module",
  "files": [
    "extensions",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint extensions",
    "format": "oxfmt --write extensions",
    "format:check": "oxfmt --check extensions"
  },
  "pi": {
    "extensions": [
      "./extensions/vim-mode"
    ]
  },
  "devDependencies": {
    "@types/node": "24",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  }
}
